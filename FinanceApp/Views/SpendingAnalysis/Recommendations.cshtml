@{
    ViewData["Title"] = "AI Recommendations";
}

<div class="container mt-4">
    <h2>&#x1F916; AI-Generated Recommendations</h2>
    <p class="text-muted">Personalised financial management tips powered by Claude.</p>

    @if (ViewBag.ApiUnavailable == true)
    {
        <div class="alert alert-warning mt-3">
            <h5>&#x26A0;&#xFE0F; AI Recommendations Unavailable</h5>
            <p class="mb-0">The Anthropic API key is not configured in this environment.
            To enable AI recommendations, add <code>Anthropic__ApiKey=your-key</code>
            to the environment configuration.</p>
        </div>
    }
    else if (ViewBag.Recommendations != null)
    {
        <div class="card mt-3">
            <div class="card-header">&#x2728; Your Personalised Recommendations</div>
            <div class="card-body">
                <div class="ai-response">
                    @Html.Raw(Markdig.Markdown.ToHtml((string)ViewBag.Recommendations))
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Back to Dashboard
        </a>
    </div>
</div>
