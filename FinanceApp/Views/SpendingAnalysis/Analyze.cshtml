@{
    ViewData["Title"] = "Spending Analysis";
}

<div class="container mt-4">
    <h2>&#x1F4CA; Spending Analysis</h2>
    <p class="text-muted">AI-powered insights into your spending habits, powered by Claude.</p>

    @if (ViewBag.ApiUnavailable == true)
    {
        <div class="alert alert-warning mt-3">
            <h5>&#x26A0;&#xFE0F; AI Analysis Unavailable</h5>
            <p class="mb-0">The Anthropic API key is not configured in this environment.
            To enable AI analysis, add <code>Anthropic__ApiKey=your-key</code> to the
            environment configuration.</p>
        </div>
    }
    else if (ViewBag.AnalysisResult != null)
    {
        <div class="card mt-3">
            <div class="card-header">&#x1F916; Analysis Results</div>
            <div class="card-body">
                <pre style="white-space: pre-wrap; font-family: inherit;">@ViewBag.AnalysisResult</pre>
            </div>
        </div>
    }
    else
    {
        <div class="card mt-3">
            <div class="card-body text-center text-muted py-5">
                <p>Click the button below to analyse your spending habits.</p>
                <a asp-controller="SpendingAnalysis" asp-action="Analyze"
                   class="btn btn-primary">Analyse My Spending</a>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Back to Dashboard
        </a>
    </div>
</div>
