# Copy to .env (gitignored) and fill in real values.
# docker compose reads .env automatically and injects these as container
# environment variables; the .NET runtime itself never loads this file.

# Anthropic API key for the spending-analysis feature (console.anthropic.com).
# Leave empty to run without AI analysis.
ANTHROPIC_API_KEY=

# SendGrid API key for the registration confirm-email flow.
# Leave empty to run without outgoing email.
SENDGRID_API_KEY=

# Verified sender address for outgoing email. Required if SENDGRID_API_KEY
# is set (startup validation enforces this), ignored otherwise.
SENDGRID_SENDER_EMAIL=

# Password for the demo user (demo@fintrak.example) seeded when
# SEED_DEMO_DATA=true. Leave empty to skip demo seeding. Must satisfy the
# Identity password policy (uppercase, lowercase, digit, symbol, 6+ chars).
SEED_DEMO_PASSWORD=
